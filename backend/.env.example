# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Frontend ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/intelligence_documentaire
# Atlas:   mongodb+srv://user:password@cluster.mongodb.net/intelligence_documentaire
MONGODB_URI=mongodb://localhost:27017/intelligence_documentaire

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Optional: Free models available, but some accounts require credits
# Get a key at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Groq (Recommended — Genuinely Free, No Credits Needed) ──────────────────
# Groq offers free API access with fast Llama, Mistral, Gemma models
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# ─── Ollama (Local — Completely Free) ────────────────────────────────────────
# If you have Ollama installed locally, it will be used as a fallback
# Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_MAX=20

# ─── OCR ─────────────────────────────────────────────────────────────────────
# Tesseract language codes — use + to combine
OCR_LANGUAGES=fra+eng

# ─── Queue (optional — for production with Redis/BullMQ) ─────────────────────
REDIS_URL=redis://localhost:6379
USE_SIMPLE_QUEUE=true

# ─── Auto Verify (Dev convenience) ───────────────────────────────────────────
# Set to true to skip email verification on registration (dev only)
AUTO_VERIFY=false
